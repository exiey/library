/* 文章场景相关 */
.page-container.data-v-d15799e0 {
  min-height: 100vh;
  background-color: #f7f9fc;
}
.content-scroll.data-v-d15799e0 {
  height: calc(100vh - 44px - 120rpx);
  /* 减去导航和底部栏高度 */
}
/* 顶部图片 */
.header-banner.data-v-d15799e0 {
  width: 100%;
  height: 480rpx;
  position: relative;
}
.banner-img.data-v-d15799e0 {
  width: 100%;
  height: 100%;
}
.banner-mask.data-v-d15799e0 {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.3), transparent);
}
/* 内容卡片 */
.main-card.data-v-d15799e0 {
  margin: -60rpx 30rpx 30rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx 30rpx;
  position: relative;
  z-index: 5;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.05);
}
.room-title.data-v-d15799e0 {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: block;
  margin-bottom: 20rpx;
}
.tag-row.data-v-d15799e0 {
  display: flex;
  gap: 16rpx;
}
.status-tag.data-v-d15799e0 {
  font-size: 22rpx;
  color: #4facfe;
  background: rgba(79, 172, 254, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}
/* 通用板块 */
.section-box.data-v-d15799e0 {
  margin: 0 30rpx 30rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
}
.section-title.data-v-d15799e0 {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}
.title-line.data-v-d15799e0 {
  width: 8rpx;
  height: 30rpx;
  background: #4facfe;
  border-radius: 4rpx;
  margin-right: 16rpx;
}
.title-line.orange.data-v-d15799e0 {
  background: #ff9d00;
}
.section-title text.data-v-d15799e0 {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.rich-content.data-v-d15799e0 {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}
/* 评价框美化 */
.eval-card.data-v-d15799e0 {
  border: 2rpx solid rgba(79, 172, 254, 0.2);
}
.rate-box.data-v-d15799e0 {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}
.rate-hint.data-v-d15799e0 {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
}
.submit-btn-box.data-v-d15799e0 {
  margin-top: 24rpx;
}
/* 评价列表 */
.replay-list.data-v-d15799e0 {
  margin-top: 10rpx;
}
.replay-item.data-v-d15799e0 {
  padding-bottom: 30rpx;
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #f1f5f9;
}
.replay-item.data-v-d15799e0:last-child {
  border-bottom: none;
  margin-bottom: 0;
}
.replay-header.data-v-d15799e0 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.user-info.data-v-d15799e0 {
  display: flex;
  align-items: center;
}
.user-avatar.data-v-d15799e0 {
  font-size: 32rpx;
  margin-right: 12rpx;
}
.user-name.data-v-d15799e0 {
  font-size: 28rpx;
  font-weight: bold;
  color: #444;
}
.replay-date.data-v-d15799e0 {
  font-size: 22rpx;
  color: #999;
}
.replay-content.data-v-d15799e0 {
  background-color: #f8fafc;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}
.empty-hint.data-v-d15799e0 {
  text-align: center;
  color: #ccc;
  font-size: 24rpx;
  padding: 40rpx 0;
}
/* 底部功能栏 */
.footer-bar.data-v-d15799e0 {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
}
.footer-inner.data-v-d15799e0 {
  height: 120rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}
.fav-action.data-v-d15799e0 {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
}
.fav-icon.data-v-d15799e0 {
  font-size: 40rpx;
}
.fav-text.data-v-d15799e0 {
  font-size: 20rpx;
  color: #666;
  margin-top: 4rpx;
}
.primary-btns.data-v-d15799e0 {
  flex: 1;
  display: flex;
  gap: 20rpx;
}
.action-btn.data-v-d15799e0 {
  flex: 1;
  height: 84rpx;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}
.scan-btn.data-v-d15799e0 {
  background-color: #f0f7ff;
  color: #4facfe;
  border: 2rpx solid #4facfe;
}
.query-btn.data-v-d15799e0 {
  background: linear-gradient(to right, #4facfe, #00b4db);
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(79, 172, 254, 0.3);
}
.safe-bottom.data-v-d15799e0 {
  height: 60rpx;
}
/* Web适配 */
@media screen and (min-width: 750px) {
.content-scroll.data-v-d15799e0, .footer-bar.data-v-d15799e0 {
    max-width: 500px;
    margin: 0 auto;
    left: 0;
    right: 0;
}
}

