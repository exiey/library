/* 文章场景相关 */
.page-container.data-v-17b5f47f {
  min-height: 100vh;
  background-color: #f7f9fc;
}
.content-scroll.data-v-17b5f47f {
  height: calc(100vh - 44px);
}
/* 顶部推荐卡片 */
.hero-section.data-v-17b5f47f {
  padding: 30rpx;
}
.recommend-card.data-v-17b5f47f {
  background: linear-gradient(135deg, #4facfe 0%, #00b4db 100%);
  border-radius: 30rpx;
  padding: 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 15rpx 30rpx rgba(79, 172, 254, 0.3);
  position: relative;
  overflow: hidden;
}
.recommend-card.data-v-17b5f47f::after {
  content: '';
  position: absolute;
  right: -20rpx;
  top: -20rpx;
  width: 150rpx;
  height: 150rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}
.rec-title.data-v-17b5f47f {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}
.rec-sub.data-v-17b5f47f {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}
.rec-icon.data-v-17b5f47f {
  width: 90rpx;
  height: 90rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.emoji-jump.data-v-17b5f47f {
  font-size: 40rpx;
}
/* 列表标题 */
.list-title-box.data-v-17b5f47f {
  padding: 0 30rpx 20rpx;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}
.list-title.data-v-17b5f47f {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.list-count.data-v-17b5f47f {
  font-size: 24rpx;
  color: #999;
}
/* 自习室卡片布局 */
.room-grid.data-v-17b5f47f {
  padding: 0 30rpx;
}
.room-card.data-v-17b5f47f {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
  transition: all 0.3s;
}
.card-hover.data-v-17b5f47f {
  -webkit-transform: scale(0.98);
          transform: scale(0.98);
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.05);
}
.room-image-box.data-v-17b5f47f {
  width: 100%;
  height: 300rpx;
  position: relative;
}
.room-img.data-v-17b5f47f {
  width: 100%;
  height: 100%;
}
.room-tag.data-v-17b5f47f {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  background: rgba(0, 0, 0, 0.5);
  -webkit-backdrop-filter: blur(4px);
          backdrop-filter: blur(4px);
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}
.room-info.data-v-17b5f47f {
  padding: 24rpx;
}
.room-header.data-v-17b5f47f {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.room-name.data-v-17b5f47f {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}
.room-arrow.data-v-17b5f47f {
  font-size: 22rpx;
  color: #4facfe;
  font-weight: 500;
}
.room-note.data-v-17b5f47f {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 20rpx;
}
.room-features.data-v-17b5f47f {
  display: flex;
  gap: 12rpx;
}
.feature-tag.data-v-17b5f47f {
  font-size: 20rpx;
  color: #888;
  background: #f0f3f6;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}
/* 空状态 */
.empty-state.data-v-17b5f47f {
  padding: 100rpx 0;
  text-align: center;
}
.empty-emoji.data-v-17b5f47f {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  display: block;
}
.empty-txt.data-v-17b5f47f {
  color: #999;
  font-size: 26rpx;
}
.safe-bottom.data-v-17b5f47f {
  height: 60rpx;
}
/* PC端适配 */
@media screen and (min-width: 750px) {
.content-scroll.data-v-17b5f47f {
    max-width: 500px;
    margin: 0 auto;
    background: #fff;
    border-left: 1px solid #eee;
    border-right: 1px solid #eee;
}
}

