  justify-content: center;
  border: 1px solid rgba(255, 255, 255, 0.3);
}
.ai-pulse-icon.data-v-1eae1885 {
  font-size: 50rpx;
  -webkit-animation: pulse-data-v-1eae1885 2s infinite;
          animation: pulse-data-v-1eae1885 2s infinite;
}
@-webkit-keyframes pulse-data-v-1eae1885 {
0% {
    -webkit-transform: scale(1);
            transform: scale(1);
    opacity: 1;
}
50% {
    -webkit-transform: scale(1.1);
            transform: scale(1.1);
    opacity: 0.8;
}
100% {
    -webkit-transform: scale(1);
            transform: scale(1);
    opacity: 1;
}
}
@keyframes pulse-data-v-1eae1885 {
0% {
    -webkit-transform: scale(1);
            transform: scale(1);
    opacity: 1;
}
50% {
    -webkit-transform: scale(1.1);
            transform: scale(1.1);
    opacity: 0.8;
}
100% {
    -webkit-transform: scale(1);
            transform: scale(1);
    opacity: 1;
}
}
