/* 文章场景相关 */
.page-container.data-v-1eae1885 {
  min-height: 100vh;
  background-color: #f4f7fc;
}
.content-scroll.data-v-1eae1885 {
  height: calc(100vh - 44px);
}
/* 智能头部装饰 */
.ai-header.data-v-1eae1885 {
  margin: 24rpx;
  padding: 40rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  border-radius: 40rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(79, 172, 254, 0.2);
}
.ai-content.data-v-1eae1885 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  z-index: 2;
}
.ai-title.data-v-1eae1885 {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}
.ai-desc.data-v-1eae1885 {
  color: rgba(255, 255, 255, 0.8);
