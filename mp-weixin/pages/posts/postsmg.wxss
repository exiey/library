.edit-page.data-v-f491db70 {
  background-color: #f4f7f9;
  min-height: 100vh;
}
.svcontainer.data-v-f491db70 {
  height: calc(100vh - 44px);
}
.content-wrapper.data-v-f491db70 {
  padding: 30rpx;
  /* Web端在大屏下的显示优化 */
  max-width: 800px;
  margin: 0 auto;
}
.info-header.data-v-f491db70 {
  margin-bottom: 40rpx;
  padding-left: 10rpx;
}
.info-header .info-title.data-v-f491db70 {
  font-size: 36rpx;
  font-weight: 800;
  color: #334155;
  display: block;
}
.info-header .info-desc.data-v-f491db70 {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 8rpx;
  display: block;
}
/* 卡片式表单样式 */
.form-card.data-v-f491db70 {
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 20rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
  margin-bottom: 40rpx;
}
.form-card .form-group.data-v-f491db70 {
  padding: 30rpx 0;
  border-bottom: 1px solid #f1f5f9;
}
.form-card .form-group.data-v-f491db70:last-child {
  border-bottom: none;
}
.form-card .form-group.no-border.data-v-f491db70 {
  border-bottom: none;
}
.form-card .form-group .label-box.data-v-f491db70 {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.form-card .form-group .label-box .icon.data-v-f491db70 {
  font-size: 32rpx;
  margin-right: 12rpx;
}
.form-card .form-group .label-box .label-text.data-v-f491db70 {
  font-size: 28rpx;
  font-weight: 600;
  color: #475569;
}
/* 输入控件美化 */
.custom-input.data-v-f491db70 {
  height: 88rpx;
  background-color: #f8fafc;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1e293b;
  border: 1px solid transparent;
  transition: all 0.3s ease;
}
.custom-input.data-v-f491db70:focus {
  background-color: #ffffff;
  border-color: #3b82f6;
}
.ph-style.data-v-f491db70 {
  color: #cbd5e1;
}
/* 编辑器容器 */
.editor-wrapper.data-v-f491db70 {
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #ffffff;
}
/* 按钮样式 */
.footer-actions.data-v-f491db70 {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}
.footer-actions .btn-submit.data-v-f491db70 {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  height: 100rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.2);
  transition: -webkit-transform 0.2s;
  transition: transform 0.2s;
  transition: transform 0.2s, -webkit-transform 0.2s;
}
.footer-actions .btn-submit.data-v-f491db70:active {
  -webkit-transform: scale(0.98);
          transform: scale(0.98);
}
.footer-actions .btn-submit .btn-text.data-v-f491db70 {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
}
.footer-actions .btn-delete.data-v-f491db70 {
  margin-top: 30rpx;
  height: 90rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #fee2e2;
  background-color: #fff1f0;
}
.footer-actions .btn-delete.data-v-f491db70:active {
  background-color: #fecaca;
}
.footer-actions .btn-delete .btn-text.data-v-f491db70 {
  color: #ef4444;
  font-size: 28rpx;
  font-weight: 500;
}
