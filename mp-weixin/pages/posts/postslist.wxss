/* 容器背景色，增加清新感 */
.page-container.data-v-6ba925cc {
  background-color: #f7f8fa;
  min-height: 100vh;
}
.svcontainer.data-v-6ba925cc {
  height: calc(100vh - 44px);
  /* 减去顶部高度 */
  display: flex;
  flex-direction: column;
}
/* 顶部 Banner 样式 */
.header-banner.data-v-6ba925cc {
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eef2f3 100%);
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}
.header-banner .banner-content.data-v-6ba925cc {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.header-banner .text-group .main-title.data-v-6ba925cc {
  font-size: 44rpx;
  font-weight: 800;
  color: #2c3e50;
  display: block;
  margin-bottom: 8rpx;
}
.header-banner .text-group .sub-title.data-v-6ba925cc {
  font-size: 24rpx;
  color: #7f8c8d;
}
.header-banner .stat-badge.data-v-6ba925cc {
  background-color: #ffffff;
  padding: 15rpx 25rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
}
.header-banner .stat-badge .num.data-v-6ba925cc {
  font-size: 36rpx;
  font-weight: bold;
  color: #3b82f6;
}
.header-banner .stat-badge .unit.data-v-6ba925cc {
  font-size: 20rpx;
  color: #94a3b8;
}
/* 新增按钮美化 */
.action-section.data-v-6ba925cc {
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}
.action-section .btn-wrapper.data-v-6ba925cc {
  background: #3b82f6;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 20rpx rgba(59, 130, 246, 0.3);
  transition: -webkit-transform 0.2s ease;
  transition: transform 0.2s ease;
  transition: transform 0.2s ease, -webkit-transform 0.2s ease;
}
.action-section .btn-wrapper.data-v-6ba925cc:active {
  -webkit-transform: scale(0.98);
          transform: scale(0.98);
  opacity: 0.9;
}
.action-section .btn-wrapper .btn-icon.data-v-6ba925cc {
  font-size: 32rpx;
  margin-right: 12rpx;
}
.action-section .btn-wrapper .btn-text.data-v-6ba925cc {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}
/* 列表包装器 */
.list-wrapper.data-v-6ba925cc {
  padding: 0 20rpx;
}
.list-wrapper .list-inner.data-v-6ba925cc {
  background-color: transparent;
  /* 穿透修改内部组件样式(可选) */
}
.list-wrapper .list-inner.data-v-6ba925cc  .imglist-item {
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
/* 空状态样式 */
.empty-state.data-v-6ba925cc {
  padding-top: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.empty-state .empty-icon.data-v-6ba925cc {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  -webkit-filter: grayscale(0.5);
          filter: grayscale(0.5);
}
.empty-state .empty-text.data-v-6ba925cc {
  color: #94a3b8;
  font-size: 28rpx;
}
/* 适配刘海屏 */
.safe-area-inset-bottom.data-v-6ba925cc {
  height: 0px;
  padding-bottom: env(safe-area-inset-bottom);
}
/* Web端适配：限制最大宽度防止拉伸过宽 */
@media screen and (min-width: 768px) {
.page-container.data-v-6ba925cc {
    max-width: 600px;
    margin: 0 auto;
    border-left: 1px solid #eee;
    border-right: 1px solid #eee;
}
}

