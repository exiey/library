/* 文章场景相关 */
.page-container.data-v-259fb574 {
  min-height: 100vh;
  background-color: #f4f7fa;
}
/* 顶部背景 */
.profile-header-bg.data-v-259fb574 {
  height: 400rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  position: relative;
  border-bottom-left-radius: 60rpx;
  border-bottom-right-radius: 60rpx;
}
.wave-decoration.data-v-259fb574 {
  position: absolute;
  bottom: 0;
  width: 100%;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
  border-top-left-radius: 100%;
  border-top-right-radius: 100%;
}
/* 主体内容 */
.main-content.data-v-259fb574 {
  padding: 0 32rpx;
  margin-top: -160rpx;
  position: relative;
  z-index: 10;
}
/* 用户卡片 */
.user-card.data-v-259fb574 {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 32rpx;
}
.user-info-row.data-v-259fb574 {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}
.avatar-box.data-v-259fb574 {
  width: 120rpx;
  height: 120rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}
.avatar-img.data-v-259fb574 {
  width: 100%;
  height: 100%;
}
.user-meta.data-v-259fb574 {
  flex: 1;
  margin-left: 30rpx;
}
.user-name.data-v-259fb574 {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}
.trust-badge.data-v-259fb574 {
  display: inline-flex;
  align-items: center;
  background: #f0f7ff;
  padding: 4rpx 20rpx;
  border-radius: 100rpx;
}
.trust-icon.data-v-259fb574 {
  font-size: 24rpx;
  margin-right: 8rpx;
}
.trust-text.data-v-259fb574 {
  font-size: 24rpx;
  color: #4facfe;
  font-weight: bold;
}
.edit-icon.data-v-259fb574 {
  font-size: 40rpx;
  color: #999;
}
/* 统计栏 */
.stats-row.data-v-259fb574 {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding-top: 30rpx;
  border-top: 1rpx solid #f1f5f9;
}
.stats-item.data-v-259fb574 {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stats-num.data-v-259fb574 {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}
.stats-label.data-v-259fb574 {
  font-size: 22rpx;
  color: #94a3b8;
}
.stats-divider.data-v-259fb574 {
  width: 1rpx;
  height: 40rpx;
  background-color: #e2e8f0;
}
.color-blue.data-v-259fb574 {
  color: #4facfe;
}
.color-orange.data-v-259fb574 {
  color: #f59e0b;
}
.color-red.data-v-259fb574 {
  color: #ef4444;
}
/* 菜单列表 */
.menu-section.data-v-259fb574 {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 10rpx 0;
  margin-bottom: 32rpx;
}
.menu-item.data-v-259fb574 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  transition: background 0.2s;
}
.menu-item.data-v-259fb574:active {
  background-color: #f8fafc;
}
.menu-left.data-v-259fb574 {
  display: flex;
  align-items: center;
}
.menu-icon.data-v-259fb574 {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 24rpx;
}
.menu-text.data-v-259fb574 {
  font-size: 30rpx;
  color: #334155;
  font-weight: 500;
}
.menu-arrow.data-v-259fb574 {
  font-size: 24rpx;
  color: #cbd5e1;
}
/* 菜单图标背景 */
.bg-blue-light.data-v-259fb574 {
  background-color: #eff6ff;
}
.bg-pink-light.data-v-259fb574 {
  background-color: #fff1f2;
}
.bg-green-light.data-v-259fb574 {
  background-color: #f0fdf4;
}
.bg-purple-light.data-v-259fb574 {
  background-color: #f5f3ff;
}
/* 退出登录 */
.logout-section.data-v-259fb574 {
  margin-top: 40rpx;
}
.logout-btn.data-v-259fb574 {
  background-color: #ffffff;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ef4444;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 15rpx rgba(239, 68, 68, 0.05);
}
.logout-btn.data-v-259fb574:active {
  opacity: 0.8;
  background-color: #fef2f2;
}
.safe-bottom-pad.data-v-259fb574 {
  height: 60rpx;
}
/* 阴影库 */
.shadow-sm.data-v-259fb574 {
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.02);
}
.shadow-blur.data-v-259fb574 {
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.05);
}
/* Web端适配 */
@media screen and (min-width: 750px) {
.main-content.data-v-259fb574 {
    max-width: 500px;
    margin: -160rpx auto 0;
}
.profile-header-bg.data-v-259fb574 {
    max-width: 500px;
    margin: 0 auto;
}
}

