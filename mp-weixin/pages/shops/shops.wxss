/* 文章场景相关 */
.page-container.data-v-6b5ffe82 {
  min-height: 100vh;
  background-color: #f8fafc;
}
.content-scroll.data-v-6b5ffe82 {
  height: calc(100vh - 44px);
}
/* 顶部引导 */
.header-hint.data-v-6b5ffe82 {
  padding: 40rpx 32rpx;
  background-color: #ffffff;
}
.hint-main.data-v-6b5ffe82 {
  font-size: 36rpx;
  font-weight: bold;
  color: #1e293b;
  display: block;
}
.hint-sub.data-v-6b5ffe82 {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 8rpx;
  display: block;
}
/* 列表容器 */
.shop-list.data-v-6b5ffe82 {
  padding: 24rpx;
}
/* 门店卡片 */
.shop-card.data-v-6b5ffe82 {
  background-color: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
  transition: all 0.3s ease;
}
.card-hover-effect.data-v-6b5ffe82 {
  -webkit-transform: translateY(-4rpx);
          transform: translateY(-4rpx);
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.08);
}
/* 图片区域 */
.shop-image-wrapper.data-v-6b5ffe82 {
  width: 100%;
  height: 360rpx;
  position: relative;
}
.shop-img.data-v-6b5ffe82 {
  width: 100%;
  height: 100%;
}
.image-overlay.data-v-6b5ffe82 {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.4), transparent);
}
.status-tag.data-v-6b5ffe82 {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  background-color: #10b981;
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 20rpx;
  border-radius: 100rpx;
  z-index: 2;
  box-shadow: 0 4rpx 10rpx rgba(16, 185, 129, 0.3);
}
/* 文字区域 */
.shop-content.data-v-6b5ffe82 {
  padding: 24rpx;
}
.shop-header.data-v-6b5ffe82 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.shop-title.data-v-6b5ffe82 {
  font-size: 34rpx;
  font-weight: bold;
  color: #0f172a;
}
.rating.data-v-6b5ffe82 {
  font-size: 20rpx;
}
.shop-address.data-v-6b5ffe82 {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.loc-icon.data-v-6b5ffe82 {
  font-size: 28rpx;
  margin-right: 12rpx;
}
.address-text.data-v-6b5ffe82 {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.4;
  /* 两行省略 */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}
/* 底部标签与按钮 */
.shop-footer.data-v-6b5ffe82 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f1f5f9;
}
.features.data-v-6b5ffe82 {
  display: flex;
  gap: 12rpx;
}
.feat-tag.data-v-6b5ffe82 {
  font-size: 20rpx;
  color: #4facfe;
  background-color: rgba(79, 172, 254, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.enter-btn.data-v-6b5ffe82 {
  display: flex;
  align-items: center;
  color: #4facfe;
  font-size: 24rpx;
  font-weight: 600;
}
.arrow-icon.data-v-6b5ffe82 {
  margin-left: 8rpx;
  transition: -webkit-transform 0.2s;
  transition: transform 0.2s;
  transition: transform 0.2s, -webkit-transform 0.2s;
}
.shop-card:active .arrow-icon.data-v-6b5ffe82 {
  -webkit-transform: translateX(6rpx);
          transform: translateX(6rpx);
}
/* 空状态 */
.empty-box.data-v-6b5ffe82 {
  padding: 120rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.empty-emoji.data-v-6b5ffe82 {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}
.empty-text.data-v-6b5ffe82 {
  font-size: 28rpx;
  color: #94a3b8;
}
.safe-bottom.data-v-6b5ffe82 {
  height: 60rpx;
}
/* PC/Web端适配优化 */
@media screen and (min-width: 750px) {
.content-scroll.data-v-6b5ffe82 {
    max-width: 480px;
    margin: 0 auto;
    background-color: #fff;
    box-shadow: 0 0 20rpx rgba(0, 0, 0, 0.05);
}
}

