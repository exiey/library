/* 文章场景相关 */
.page-container.data-v-57280228 {
  min-height: 100vh;
  background-color: #f8fafc;
}
.content-scroll.data-v-57280228 {
  height: calc(100vh - 44px);
}
/* 1. 轮播图样式美化 */
.swiper-section.data-v-57280228 {
  padding: 24rpx;
  background-color: #fff;
}
.main-swiper.data-v-57280228 {
  height: 360rpx;
  /* 稍微加高一点 */
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.1);
  /* 强制兼容某些平台的圆角 */
  -webkit-transform: translateY(0);
          transform: translateY(0);
}
.swiper-item-wrapper.data-v-57280228 {
  position: relative;
  width: 100%;
  height: 100%;
  background-color: #f1f5f9;
  /* 加载前的底色 */
}
.swiper-img.data-v-57280228 {
  width: 100%;
  height: 100%;
  display: block;
}
.swiper-title-mask.data-v-57280228 {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 60rpx 24rpx 24rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, transparent 100%);
  pointer-events: none;
}
.swiper-title.data-v-57280228 {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}
.swiper-placeholder.data-v-57280228 {
  height: 360rpx;
  background-color: #f1f5f9;
  border-radius: 24rpx;
}
/* 2. 金刚区 */
.menu-card.data-v-57280228 {
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 36rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
}
.grid-layout.data-v-57280228 {
  display: flex;
  justify-content: space-around;
}
.grid-item.data-v-57280228 {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.grid-item.data-v-57280228:active {
  opacity: 0.7;
}
.icon-box.data-v-57280228 {
  width: 100rpx;
  height: 100rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}
.emoji-icon.data-v-57280228 {
  font-size: 48rpx;
}
.bg-light-blue.data-v-57280228 {
  background: linear-gradient(135deg, #eef7ff, #e0f2fe);
}
.bg-light-green.data-v-57280228 {
  background: linear-gradient(135deg, #f0fdf4, #dcfce7);
}
.bg-light-orange.data-v-57280228 {
  background: linear-gradient(135deg, #fff7ed, #ffedd5);
}
.bg-light-purple.data-v-57280228 {
  background: linear-gradient(135deg, #f5f3ff, #ede9fe);
}
.grid-label.data-v-57280228 {
  font-size: 26rpx;
  color: #1e293b;
  font-weight: 500;
}
/* 3. 列表标题 */
.section-header.data-v-57280228 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx 10rpx;
}
.section-title.data-v-57280228 {
  display: flex;
  align-items: center;
  font-size: 34rpx;
  font-weight: 800;
  color: #1e293b;
}
.title-line.data-v-57280228 {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(#4facfe, #00f2fe);
  border-radius: 4rpx;
  margin-right: 16rpx;
}
.more-text.data-v-57280228 {
  font-size: 24rpx;
  color: #94a3b8;
}
/* 资讯列表项 */
.notice-list.data-v-57280228 {
  padding: 20rpx 24rpx;
}
.notice-item.data-v-57280228 {
  display: flex;
  background-color: #ffffff;
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.02);
  border: 1rpx solid #f1f5f9;
}
.item-hover.data-v-57280228 {
  background-color: #f8fafc;
}
.notice-cover.data-v-57280228 {
  width: 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  background-color: #f1f5f9;
}
.notice-content.data-v-57280228 {
  flex: 1;
  margin-left: 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.notice-title.data-v-57280228 {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}
.notice-desc.data-v-57280228 {
  font-size: 26rpx;
  color: #64748b;
  margin-top: 10rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.notice-footer.data-v-57280228 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}
.notice-tag.data-v-57280228 {
  font-size: 20rpx;
  color: #3b82f6;
  background: #eff6ff;
  padding: 4rpx 16rpx;
  border-radius: 10rpx;
  font-weight: 600;
}
.notice-arrow.data-v-57280228 {
  font-size: 24rpx;
  color: #3b82f6;
  font-weight: 500;
}
.empty-box.data-v-57280228 {
  padding: 120rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.empty-icon.data-v-57280228 {
  font-size: 100rpx;
  opacity: 0.2;
}
.empty-text.data-v-57280228 {
  color: #cbd5e1;
  font-size: 28rpx;
  margin-top: 20rpx;
}
.safe-bottom.data-v-57280228 {
  height: 80rpx;
}
/* 适配 PC Web 端 */
@media screen and (min-width: 768px) {
.page-container.data-v-57280228 {
    max-width: 600px;
    margin: 0 auto;
    border-left: 1rpx solid #e2e8f0;
    border-right: 1rpx solid #e2e8f0;
}
