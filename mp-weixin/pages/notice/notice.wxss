/* 文章场景相关 */
.notice-page.data-v-0b680ac6 {
  background-color: #f6f8fa;
  min-height: 100vh;
}
.svcontainer.data-v-0b680ac6 {
  height: calc(100vh - 44px);
}
/* 顶部装饰条 */
.header-banner.data-v-0b680ac6 {
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eef2f3 100%);
  margin-bottom: 20rpx;
}
.header-banner .banner-inner.data-v-0b680ac6 {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.header-banner .banner-left .banner-title.data-v-0b680ac6 {
  font-size: 44rpx;
  font-weight: 800;
  color: #2c3e50;
  display: block;
}
.header-banner .banner-left .banner-subtitle.data-v-0b680ac6 {
  font-size: 24rpx;
  color: #7f8c8d;
  margin-top: 8rpx;
  display: block;
}
.header-banner .banner-icon.data-v-0b680ac6 {
  font-size: 60rpx;
  opacity: 0.8;
}
/* 公告列表容器 */
.notice-list.data-v-0b680ac6 {
  padding: 0 24rpx;
}
/* 原生卡片样式 */
.notice-card.data-v-0b680ac6 {
  background-color: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #f0f0f0;
  transition: -webkit-transform 0.2s ease;
  transition: transform 0.2s ease;
  transition: transform 0.2s ease, -webkit-transform 0.2s ease;
}
.notice-card.data-v-0b680ac6:active {
  -webkit-transform: scale(0.98);
          transform: scale(0.98);
  background-color: #fafafa;
}
.notice-card .card-body.data-v-0b680ac6 {
  display: flex;
  flex-direction: column;
  /* 默认纵向，如果有图可改为横向 */
}
.notice-card .card-body .notice-img.data-v-0b680ac6 {
  width: 100%;
  height: 280rpx;
  background-color: #eee;
}
.notice-card .card-body .notice-content.data-v-0b680ac6 {
  padding: 24rpx;
}
.title-row.data-v-0b680ac6 {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.title-row .notice-tag.data-v-0b680ac6 {
  background-color: #e3f2fd;
  color: #2196f3;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  font-weight: bold;
  flex-shrink: 0;
}
.title-row .notice-title.data-v-0b680ac6 {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.notice-brief.data-v-0b680ac6 {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  /* 限制两行预览 */
  overflow: hidden;
  margin-bottom: 20rpx;
}
.notice-footer.data-v-0b680ac6 {
  border-top: 1rpx solid #f5f5f5;
  padding-top: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.notice-footer .date-info.data-v-0b680ac6 {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #999;
}
.notice-footer .date-info .calendar-icon.data-v-0b680ac6 {
  margin-right: 8rpx;
  font-size: 24rpx;
}
.notice-footer .detail-link.data-v-0b680ac6 {
  font-size: 24rpx;
  color: #2196f3;
  font-weight: 500;
}
/* 空状态 */
.empty-state.data-v-0b680ac6 {
  padding: 100rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.empty-state .empty-emoji.data-v-0b680ac6 {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}
.empty-state .empty-text.data-v-0b680ac6 {
  color: #999;
  font-size: 28rpx;
}
.safe-area-bottom.data-v-0b680ac6 {
  height: env(safe-area-inset-bottom);
  padding-bottom: 40rpx;
}
/* Web端适配 */
@media screen and (min-width: 768px) {
.notice-page.data-v-0b680ac6 {
    max-width: 600px;
    margin: 0 auto;
    border-left: 1rpx solid #eaeaea;
    border-right: 1rpx solid #eaeaea;
}
}

