/* 容器背景色 */
.detail-container.data-v-1b0f8fd2 {
  min-height: 100vh;
  background-color: #ffffff;
}
.detail-scroll.data-v-1b0f8fd2 {
  height: calc(100vh - 44px);
  /* 动态减去导航栏高度 */
}
.article-wrapper.data-v-1b0f8fd2 {
  padding: 30rpx 40rpx;
}
/* 标题区样式 */
.header-section.data-v-1b0f8fd2 {
  margin-bottom: 40rpx;
}
.article-title.data-v-1b0f8fd2 {
  font-size: 44rpx;
  color: #1a1a1a;
  line-height: 1.4;
  font-weight: 700;
  display: block;
  margin-bottom: 24rpx;
}
.meta-info.data-v-1b0f8fd2 {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}
.meta-icon.data-v-1b0f8fd2 {
  font-size: 24rpx;
  margin-right: 8rpx;
}
.meta-text.data-v-1b0f8fd2 {
  font-size: 26rpx;
  color: #8e8e93;
  margin-right: 20rpx;
}
.meta-tag.data-v-1b0f8fd2 {
  font-size: 22rpx;
  color: #4facfe;
  background-color: rgba(79, 172, 254, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-weight: 500;
}
/* 图片区样式 */
.image-section.data-v-1b0f8fd2 {
  margin: 30rpx 0;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}
.article-banner.data-v-1b0f8fd2 {
  width: 100%;
  display: block;
  /* 消除图片底部空隙 */
}
/* 正文区样式 */
.content-section.data-v-1b0f8fd2 {
  margin-top: 40rpx;
}
.content-divider.data-v-1b0f8fd2 {
  width: 60rpx;
  height: 6rpx;
  background-color: #4facfe;
  margin-bottom: 40rpx;
  border-radius: 3rpx;
}
.rich-text-container.data-v-1b0f8fd2 {
  font-size: 32rpx;
  color: #334155;
  line-height: 1.8;
  letter-spacing: 0.5rpx;
}
/* 底部装饰 */
.footer-notice.data-v-1b0f8fd2 {
  margin-top: 80rpx;
  padding-bottom: 40rpx;
  text-align: center;
}
.footer-notice text.data-v-1b0f8fd2 {
  font-size: 24rpx;
  color: #cbd5e1;
}
.safe-area-bottom.data-v-1b0f8fd2 {
  height: env(safe-area-inset-bottom);
}
/* Web端自适应排版优化 */
@media screen and (min-width: 750px) {
.article-wrapper.data-v-1b0f8fd2 {
    max-width: 700px;
    margin: 0 auto;
    padding: 60rpx 0;
}
.article-title.data-v-1b0f8fd2 {
    font-size: 56rpx;
}
.detail-container.data-v-1b0f8fd2 {
    background-color: #f8fafc;
}
.detail-scroll.data-v-1b0f8fd2 {
    background-color: #fff;
    max-width: 800px;
    margin: 0 auto;
    box-shadow: 0 0 20px rgba(0, 0, 0, 0.05);
}
}

